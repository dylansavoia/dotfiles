map W adjust_window width
map H adjust_window best-fit
map ` mark_evaluate

set selection-clipboard clipboard
set recolor-keephue true
set recolor-lightcolor "{{black0}}"

set default-bg "{{bkg_alt}}"
set default-fg "{{fg}}"
set inputbar-bg "{{bkg}}"
set inputbar-fg "{{fg}}"
set statusbar-bg "{{bkg}}"
set statusbar-fg "{{fg}}"

set notification-error-bg "{{urgent}}"
set notification-error-fg "{{fg}}"
set notification-warning-bg "{{warning}}"
set notification-warning-fg "{{fg}}"
set font "{{font}} 10"
