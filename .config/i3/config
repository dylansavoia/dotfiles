set $mod Mod4 
set $term st
set $termname st -n
set $gout 5
set $gin 10

# Startup
font pango:SFNS Display 10
exec --no-startup-id compton --config ~/.config/compton/compton.conf
exec --no-startup-id dropbox start
exec --no-startup-id ~/.local/scripts/polybar
exec_always --no-startup-id feh --no-xinerama --bg-scale ~/.config/i3/wallpaper.jpg

# UI
gaps outer $gout
gaps inner $gin

## Colors
set_from_resource $bkg0   i3wm.color0	 #000000
set_from_resource $bkg1   i3wm.color8	 #000000
set_from_resource $fg0    i3wm.color7	 #000000
set_from_resource $fg1    i3wm.color15	 #000000
set_from_resource $acc    i3wm.color16	 #000000

# class                    border   back.   text    indicator.  child_brd
client.focused             $acc     $acc    $fg1    $acc        $acc
client.unfocused           $bkg0    $bkg0   $fg1    $bkg0       $bkg0
client.focused_inactive    $bkg0    $bkg0   $fg1    $bkg0       $bkg0

# exit i3 (logs you out of your X session)
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -b 'Yes, exit i3' 'i3-msg exit'"

# Windows
focus_wrapping no
hide_edge_borders both
for_window [class="^.*"] border pixel 1

# workspace_auto_back_and_forth yes

focus_follows_mouse no

workspace 1 output HDMI-1
workspace 3 output HDMI-1
workspace 5 output HDMI-1
workspace 7 output HDMI-1
workspace 9 output HDMI-1

workspace 2 output DP-1
workspace 4 output DP-1
workspace 6 output DP-1
workspace 8 output DP-1
workspace 10 output DP-1

# assign [class="qutebrowser"] number 1

## Scratchpad
for_window [instance="applet"] floating enable
for_window [instance="applet"] resize set 800 550

for_window [instance="scratchterm"] floating enable
for_window [instance="scratchterm"] resize set 800 550
for_window [instance="scratchterm"] move scratchpad
exec --no-startup-id $termname "scratchterm"


# Keybindings
#i3 
# bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart

# Applications
bindsym $mod+f exec rofi -show run
bindsym $mod+space exec bash -ic /home/dylansavoia/.local/scripts/laser
bindsym $mod+w exec rofi -columns 2 -show window
bindsym $mod+b exec qutebrowser --enable-webengine-inspector
bindsym $mod+o exec $term -e /home/dylansavoia/.local/scripts/vifmrun
bindsym $mod+t exec $term
bindsym $mod+s [instance="scratchterm"] scratchpad show; [instance="scratchterm"] move position center
bindsym $mod+F2 exec ~/.local/scripts/screen

# Modes (stacking | tabbed | toggle split)
bindsym $mod+m layout tabbed
bindsym $mod+Shift+m layout toggle split
bindsym $mod+a floating toggle

# Resize
bindsym $mod+bracketright resize grow width 10 px or 10 ppt
bindsym $mod+bracketleft resize shrink width 10 px or 10 ppt
bindsym $mod+Shift+bracketright resize grow height 10 px or 10 ppt
bindsym $mod+Shift+bracketleft resize shrink height 10 px or 10 ppt

bindsym $mod+g gaps inner all set 0, gaps outer all set 0
bindsym $mod+Shift+g gaps inner all set $gin, gaps outer all set $gout

# Spawn
bindsym $mod+Shift+v split h
bindsym $mod+v split v

# Quit App
bindsym $mod+d kill

# switch to workspace
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10
bindsym $mod+Tab workspace next

# Focus / Move
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

bindsym $mod+Shift+1 move container to workspace number 1,  workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2,  workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3,  workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4,  workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5,  workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6,  workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7,  workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8,  workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9,  workspace number 9
bindsym $mod+Shift+0 move container to workspace number 10, workspace number 10

# Hide Mode
bindsym $mod+backslash workspace number 8, workspace number  9, exec $term -e vifm
bindsym $mod+Shift+backslash kill, workspace number 2, workspace number  1

# Power Controls
bindsym $mod+F1 exec ~/.local/scripts/power

# Audio Controls
bindsym $mod+F9   exec --no-startup-id ~/.local/scripts/set_volume.sh switch
bindsym $mod+F10  exec --no-startup-id ~/.local/scripts/set_volume.sh -10%
bindsym $mod+F11  exec --no-startup-id ~/.local/scripts/set_volume.sh +10%
bindsym $mod+F12  exec --no-startup-id ~/.local/scripts/set_volume.sh toggle

# Monitors Controls
bindsym $mod+F5 exec --no-startup-id "~/.local/scripts/monitors; ~/.local/scripts/polybar"
bindsym $mod+F6 exec --no-startup-id ~/.local/scripts/set_brightness -50
bindsym $mod+F7 exec --no-startup-id ~/.local/scripts/set_brightness +50

bindsym XF86AudioMute exec --no-startup-id amixer -D pulse sset Master toggle
