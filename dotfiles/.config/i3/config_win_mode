set $mod Mod4
set $term st
set $termname st -n
set $gout 5
set $gin 10

# Startup
font pango:SFNS Display 10
exec --no-startup-id compton --config ~/.config/i3/compton.conf
exec --no-startup-id dropbox start
exec --no-startup-id ~/.config/i3/scripts/polybar
exec_always --no-startup-id feh --no-xinerama --bg-scale ~/.config/i3/wallpaper.jpg

# UI
gaps outer $gout
gaps inner $gin

## Colors
set_from_resource $bkg0   i3wm.color0	 #000000
set_from_resource $bkg1   i3wm.color8	 #000000
set_from_resource $fg0    i3wm.color7	 #000000
set_from_resource $fg1    i3wm.color15	 #000000
set_from_resource $acc    i3wm.color16	 #000000

# class                    border   back.   text    indicator.  child_brd
client.focused             $acc     $acc    $fg1    $acc        $acc
client.unfocused           $bkg0    $bkg0   $fg1    $bkg0       $bkg0
client.focused_inactive    $bkg0    $bkg0   $fg1    $bkg0       $bkg0

# exit i3 (logs you out of your X session)
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -b 'Yes, exit i3' 'i3-msg exit'"

# Windows
focus_wrapping no
hide_edge_borders both
for_window [class="^.*"] border pixel 1

# workspace_auto_back_and_forth yes

focus_follows_mouse no

workspace 1 output HDMI-1
workspace 3 output HDMI-1
workspace 5 output HDMI-1
workspace 7 output HDMI-1
workspace 9 output HDMI-1

workspace 2 output DP-1
workspace 4 output DP-1
workspace 6 output DP-1
workspace 8 output DP-1
workspace 10 output DP-1

# assign [class="qutebrowser"] number 1

## Scratchpad
for_window [instance="applet"] floating enable
for_window [instance="applet"] resize set 800 550

for_window [instance="scratchterm"] floating enable
for_window [instance="scratchterm"] resize set 800 550
for_window [instance="scratchterm"] move scratchpad
exec --no-startup-id $termname "scratchterm"


# Keybindings
mode "Win" {
    #i3 
    bindsym Shift+c reload
    bindsym Shift+r restart

    # Applications
    bindsym f exec rofi -columns 5 -show run, mode "default"
    bindsym w exec rofi -columns 2 -show window, mode "default"
    bindsym b exec qutebrowser --enable-webengine-inspector
    bindsym o exec $term -e vifm
    bindsym t exec $term
    bindsym s [instance="scratchterm"] scratchpad show; [instance="scratchterm"] move position center; mode default;
    bindsym F2 exec ~/.config/i3/scripts/screen

    # Modes (stacking | tabbed | toggle split)
    bindsym m layout tabbed
    bindsym Shift+m layout toggle split
    bindsym a floating toggle

    # Resize
    bindsym bracketright resize grow width 10 px or 10 ppt
    bindsym bracketleft resize shrink width 10 px or 10 ppt
    bindsym Shift+bracketright resize grow height 10 px or 10 ppt
    bindsym Shift+bracketleft resize shrink height 10 px or 10 ppt

    bindsym g gaps inner all set 0, gaps outer all set 0
    bindsym Shift+g gaps inner all set $gin, gaps outer all set $gout

    # Spawn
    bindsym Shift+v split h
    bindsym v split v

    # Quit App
    bindsym Shift+q kill

    # switch to workspace
    bindsym 1 workspace number 1
    bindsym 2 workspace number 2
    bindsym 3 workspace number 3
    bindsym 4 workspace number 4
    bindsym 5 workspace number 5
    bindsym 6 workspace number 6
    bindsym 7 workspace number 7
    bindsym 8 workspace number 8
    bindsym 9 workspace number 9
    bindsym 0 workspace number 10
    bindsym Tab workspace next
    bindsym Ctrl-Tab workspace prev

    # Focus / Move
    bindsym h focus left
    bindsym j focus down
    bindsym k focus up
    bindsym l focus right

    bindsym Shift+h move left
    bindsym Shift+j move down
    bindsym Shift+k move up
    bindsym Shift+l move right

    bindsym Shift+1 move container to workspace number 1, workspace number 1
    bindsym Shift+2 move container to workspace number 2, workspace number 2
    bindsym Shift+3 move container to workspace number 3, workspace number 3
    bindsym Shift+4 move container to workspace number 4, workspace number 4
    bindsym Shift+5 move container to workspace number 5, workspace number 5
    bindsym Shift+6 move container to workspace number 6, workspace number 6
    bindsym Shift+7 move container to workspace number 7, workspace number 7
    bindsym Shift+8 move container to workspace number 8, workspace number 8
    bindsym Shift+9 move container to workspace number 9, workspace number 9
    bindsym Shift+0 move container to workspace number 10, workspace number 10

    # Hide Mode
    bindsym backslash workspace number 8, workspace number  9, exec $term -e vifm, mode "default"
    bindsym Shift+backslash kill, workspace number 2, workspace number  1, mode "default"

    # Power Controls
    bindsym F1 exec ~/.config/i3/scripts/power, mode "default"

    # Audio Controls
    bindsym F9   exec --no-startup-id ~/.config/i3/scripts/set_volume.sh switch
    bindsym F10  exec --no-startup-id ~/.config/i3/scripts/set_volume.sh -10%
    bindsym F11  exec --no-startup-id ~/.config/i3/scripts/set_volume.sh +10%
    bindsym F12  exec --no-startup-id ~/.config/i3/scripts/set_volume.sh toggle

    # Monitors Controls
    bindsym F5 exec --no-startup-id "~/.config/i3/scripts/monitors; ~/.config/i3/scripts/polybar"
    bindsym F6 exec --no-startup-id ~/.config/i3/scripts/set_brightness -50
    bindsym F7 exec --no-startup-id ~/.config/i3/scripts/set_brightness +50

    # Exit Mode
    bindsym i mode "default"
    bindsym Escape mode "default"
}

bindsym XF86AudioMute exec --no-startup-id amixer -D pulse sset Master toggle
bindcode 133 mode "Win"
bindcode 134 mode "Win"
